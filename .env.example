# ─── Backend (Railway environment variables) ─────────────────────────────────
# Copy values into Railway project settings — never commit real keys

# PostgreSQL connection string
# Railway auto-injects DATABASE_URL; use this format for .NET Npgsql
ConnectionStrings__DefaultConnection=Host=...;Port=5432;Database=orchestai;Username=...;Password=...

# Anthropic (https://console.anthropic.com)
Anthropic__ApiKey=sk-ant-...

# Azure OpenAI (https://portal.azure.com) — optional, only needed if an agent's
# model in Agents:Models is configured with the "azure/" provider prefix
AzureOpenAI__ApiKey=
AzureOpenAI__Endpoint=
AzureOpenAI__DeploymentName=

# OpenAI (https://platform.openai.com) — optional, only needed if an agent's
# model in Agents:Models is configured with the "openai/" provider prefix
OpenAI__ApiKey=

# Firecrawl (https://firecrawl.dev) — required for ResearchAgent web scraping
Tools__Firecrawl__ApiKey=fc-...

# Perplexity (https://docs.perplexity.ai) — required for ResearchAgent AI search
Tools__Perplexity__ApiKey=pplx-...

# CORS — comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=https://your-app.vercel.app,http://localhost:5173

# ─── Frontend (Vercel environment variables) ──────────────────────────────────
# Set in Vercel project settings → Environment Variables → Production

# Railway API base URL (no trailing slash)
VITE_API_URL=https://your-api.railway.app

# ─── Local development (Docker Compose) ──────────────────────────────────────
# These override appsettings.json when running via: docker compose up
POSTGRES_PASSWORD=changeme
